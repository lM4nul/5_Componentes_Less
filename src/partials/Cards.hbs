<section id="cards" class="cards-section">
    <div class="content">
        <h2>Cards</h2>
        <div class="cards-container">
            {{#each cards}}
            <article class="card">
                <h3>{{titulo}}</h3>
                <p>{{descripcion}}</p>
            </article>
            {{/each}}
        </div>
    </div>
</section>
